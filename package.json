{
  "name": "research-task-manager",
  "version": "0.3.0",
  "private": true,
  "description": "Academic task manager for tracking research projects, updates, and next steps.",
  "scripts": {
    "setup": "npm install && npm --prefix client install",
    "server": "node server/index.js",
    "client": "npm --prefix client run dev",
    "dev": "concurrently -n server,client -c magenta,cyan \"npm:server\" \"npm:client\"",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
